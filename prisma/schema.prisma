generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-App Architecture ─────────────────────────────────

model App {
  id         String             @id @default(cuid())
  name       String
  slug       String             @unique
  createdAt  DateTime           @default(now())
  namespaces ContentNamespace[]
}

// ─── Language Management ────────────────────────────────────

model Language {
  code         String        @id // BCP 47: "en", "fr", "es", "ar", "zh"...
  name         String        // "English", "French"
  nativeName   String        // "English", "Français"
  direction    String        @default("ltr") // "ltr" or "rtl"
  isActive     Boolean       @default(true)
  translations Translation[]
}

// ─── Content Management ─────────────────────────────────────

model ContentNamespace {
  id    String       @id @default(cuid())
  appId String
  app   App          @relation(fields: [appId], references: [id], onDelete: Cascade)
  name  String       // "landing", "demo", "onboarding"
  keys  ContentKey[]

  @@unique([appId, name])
}

model ContentKey {
  id           String             @id @default(cuid())
  namespaceId  String
  namespace    ContentNamespace   @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  key          String             // "hero.title", "hero.subtitle", "cta.download"
  description  String?            // Context for translators / LLM
  translations Translation[]

  @@unique([namespaceId, key])
}

model Translation {
  id           String            @id @default(cuid())
  contentKeyId String
  contentKey   ContentKey        @relation(fields: [contentKeyId], references: [id], onDelete: Cascade)
  languageCode String
  language     Language          @relation(fields: [languageCode], references: [code])
  value        String
  status       TranslationStatus @default(NOT_STARTED)
  updatedAt    DateTime          @updatedAt

  @@unique([contentKeyId, languageCode])
}

enum TranslationStatus {
  NOT_STARTED
  DRAFT
  READY
}
